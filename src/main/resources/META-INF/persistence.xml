<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence" version="2.0">

    <persistence-unit name="bookstorePU" transaction-type="RESOURCE_LOCAL">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <!-- 1. ADD FULLY QUALIFIED CLASS NAME HERE -->
        <class>org.example.Book</class>
        <class>org.example.Item</class>
        <class>org.example.Chapter</class>
        <class>org.example.Author</class>
        <class>org.example.News</class>

        <properties>
            <!-- Database Connection Settings -->
            <property name="eclipselink.target-database" value="PostgreSQL"/>
            <property name="eclipselink.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="eclipselink.jdbc.url" value="jdbc:postgresql://localhost/bookstore_persistence"/>
            <property name="eclipselink.jdbc.user" value="jcando"/>
            <property name="eclipselink.jdbc.password" value="jcando"/>

            <!-- DDL Generation: Automatically create the tables -->
            <property name="eclipselink.ddl-generation" value="drop-and-create-tables"/>
            <property name="eclipselink.logging.level" value="FINE"/>
        </properties>
    </persistence-unit>

</persistence>